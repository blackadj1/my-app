apiVersion: apps/v1
kind: Deployment
metadata:
  name: my-app-deployment
  namespace: default            # 배포를 진행할 네임스페이스 (기본 default)
  labels:
    app: my-app
spec:
  replicas: 2                   # 띄울 Pod의 개수
  selector:
    matchLabels:
      app: my-app
  template:
    metadata:
      labels:
        app: my-app
    spec:
      containers:
      - name: my-app-container
        # ★ 중요: 아래 이미지 경로가 젠킨스에 의해 자동으로 업데이트(치환)됩니다.
        image: acrenfinitymgprd.azurecr.io/my-app:6
        ports:
        - containerPort: 80     # 컨테이너가 내부적으로 사용하는 포트
---
apiVersion: v1
kind: Service
metadata:
  name: my-app-service
  namespace: default
spec:
  type: LoadBalancer            # 외부에서 테스트 접속이 가능하도록 공인 IP 발급
  ports:
  - port: 80                    # 서비스 외부 노출 포트
    targetPort: 80              # 컨테이너 내부 포트
  selector:
    app: my-app
